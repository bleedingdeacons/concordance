{
    "name": "bleeding-deacons/concordance",
    "description": "API client for the AAGBDB Groups API",
    "type": "wordpress-plugin",
    "license": "MIT (Modified)",
    "authors": [
        {
            "name": "The Bleeding Deacons"
        }
    ],
    "require": {
        "php": ">=8.1",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "php-stubs/wp-cli-stubs": "^2.12",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Concordance\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Concordance\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": "php build.php build:production",
        "build:production": "php build.php build:production",
        "build:dev": "php build.php build:dev",
        "build:clean": "php build.php clean",
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=1G"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
